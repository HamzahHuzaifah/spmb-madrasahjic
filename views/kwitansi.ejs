<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <title>Kwitansi Pembayaran SPMB JIC - <%= no_transaksi %>
    </title>
    <style>
        @page {
            size: A4 landscape;
            margin: 15mm 15mm;
            background-color: #ffffff;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', 'Helvetica', sans-serif;
            color: #2c3e50;
            margin: 0;
            padding: 0;
            font-size: 11pt;
            line-height: 1.4;
        }

        .kwitansi-border {
            border: 3px double #1b5e20;
            padding: 25px;
            background-color: #fafdfa;
            position: relative;
        }

        /* Layout menggunakan HTML Table agar aman saat diconvert ke PDF oleh Puppeteer */
        .header-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 15px;
        }

        .logo-cell {
            width: 80px;
            vertical-align: middle;
        }

        /* Ini bisa diganti dengan tag <img> logo JIC asli nanti */
        .logo-placeholder {
            width: 70px;
            height: 70px;
            background-color: #1b5e20;
            border-radius: 50%;
            text-align: center;
            color: white;
            font-weight: bold;
            font-size: 24pt;
            line-height: 70px;
        }

        .title-cell {
            vertical-align: middle;
            padding-left: 15px;
        }

        .institution-name {
            font-size: 16pt;
            font-weight: bold;
            color: #1b5e20;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin: 0;
        }

        .institution-sub {
            font-size: 9pt;
            color: #555555;
            margin: 2px 0 0 0;
        }

        .doc-title-cell {
            text-align: right;
            vertical-align: middle;
        }

        .doc-title {
            font-size: 20pt;
            font-weight: bold;
            color: #1b5e20;
            margin: 0;
            letter-spacing: 1px;
        }

        .doc-number {
            font-size: 10pt;
            color: #7f8c8d;
            margin: 4px 0 0 0;
            font-family: 'Courier New', monospace;
        }

        .divider {
            border-bottom: 2px solid #1b5e20;
            margin-bottom: 20px;
        }

        .content-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        .content-table td {
            padding: 8px 5px;
            vertical-align: top;
        }

        .label {
            width: 180px;
            font-weight: bold;
            color: #34495e;
        }

        .colon {
            width: 20px;
            text-align: center;
            color: #34495e;
        }

        .value {
            color: #2c3e50;
            border-bottom: 1px dotted #bdc3c7;
        }

        .value-highlight {
            font-weight: bold;
            color: #1b5e20;
        }

        .terbilang-container {
            width: 100%;
            background-color: #edf7ed;
            border: 1px dashed #1b5e20;
            padding: 12px 15px;
            margin-bottom: 25px;
            border-radius: 4px;
        }

        .terbilang-label {
            font-size: 9pt;
            text-transform: uppercase;
            color: #2e7d32;
            font-weight: bold;
            margin-bottom: 4px;
        }

        .terbilang-value {
            font-style: italic;
            font-weight: bold;
            font-size: 12pt;
            color: #1b5e20;
        }

        .footer-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        .amount-cell {
            width: 50%;
            vertical-align: middle;
        }

        .amount-box {
            background-color: #1b5e20;
            color: #ffffff;
            font-size: 16pt;
            font-weight: bold;
            padding: 12px 25px;
            display: inline-block;
            border-radius: 4px;
            font-family: 'Courier New', monospace;
        }

        .signature-cell {
            width: 50%;
            text-align: right;
            vertical-align: top;
            padding-right: 40px;
        }

        .date-text {
            margin-bottom: 60px;
            color: #2c3e50;
        }

        .signature-name {
            font-weight: bold;
            text-decoration: underline;
            color: #2c3e50;
            margin: 0;
        }

        .signature-role {
            font-size: 9pt;
            color: #7f8c8d;
            margin: 2px 0 0 0;
        }
    </style>
</head>

<body>

    <div class="kwitansi-border">
        <table class="header-table">
            <tr>
                <td class="logo-cell">
                    <div class="logo-placeholder">JIC</div>
                </td>
                <td class="title-cell">
                    <h1 class="institution-name">Pendidikan Jakarta Islamic Centre</h1>
                    <p class="institution-sub">Jl. Kramat Jaya Raya, Tugu Utara, Koja, Jakarta Utara</p>
                    <p class="institution-sub">Telp: (021) 4413316 | SPMB Tahun Pelajaran 2026/2027</p>
                </td>
                <td class="doc-title-cell">
                    <h2 class="doc-title">KWITANSI</h2>
                    <p class="doc-number">No: <%= no_transaksi %>
                    </p>
                </td>
            </tr>
        </table>

        <div class="divider"></div>

        <table class="content-table">
            <tr>
                <td class="label">Telah Diterima Dari</td>
                <td class="colon">:</td>
                <td class="value">
                    <%= nama_wali %> (Orang Tua / Wali Santri)
                </td>
            </tr>
            <tr>
                <td class="label">Nama Calon Santri</td>
                <td class="colon">:</td>
                <td class="value"><span class="value-highlight">
                        <%= nama_santri %>
                    </span></td>
            </tr>
            <tr>
                <td class="label">Satuan Pendidikan</td>
                <td class="colon">:</td>
                <td class="value">
                    <%= satuan_pendidikan %> (Jalur: <%= jalur_pendaftaran %>)
                </td>
            </tr>
            <tr>
                <td class="label">Untuk Pembayaran</td>
                <td class="colon">:</td>
                <td class="value">
                    <%= uraian_pembayaran %>
                </td>
            </tr>
        </table>

        <div class="terbilang-container">
            <div class="terbilang-label">Terbilang / Spelled Out</div>
            <div class="terbilang-value"># <%= terbilang %> #</div>
        </div>

        <table class="footer-table">
            <tr>
                <td class="amount-cell">
                    <div class="amount-box">
                        Rp <%= nominal_format %>,-
                    </div>
                </td>
                <td class="signature-cell">
                    <div class="date-text">Jakarta, <%= tanggal_cetak %>
                    </div>
                    <p class="signature-name">
                        <%= nama_petugas %>
                    </p>
                    <p class="signature-role">Panitia Keuangan SPMB</p>
                </td>
            </tr>
        </table>
    </div>

</body>

</html>