<%- include('partials/header', { title: 'Dashboard' , activePage: 'dashboard' }) %>

<div class="content-area">
    <!-- Header -->
    <div class="dashboard-header mb-4" style="border-left: 5px solid var(--primary); padding-left: 15px; margin-bottom: 30px;">
        <h1 style="font-size: 24px; font-weight: 700; color: var(--primary-dark); margin: 0;">Dashboard Informasi Keuangan</h1>
        <p style="color: var(--text-muted); margin: 5px 0 0 0; font-size: 14px;">Ringkasan pendaftaran dan status keuangan SPMB MJIC</p>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar mb-4">
        <form method="GET" action="/dashboard" style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap; width: 100%;">
            <div style="display: flex; align-items: center; gap: 10px;">
                <label style="font-weight: 600; white-space: nowrap; margin-bottom: 0;">Dari Tanggal:</label>
                <input type="date" name="startDate" id="startDateInput" class="form-control" style="width: 160px;" value="<%= typeof startDateQuery !== 'undefined' ? startDateQuery : '' %>">
            </div>
            <div style="display: flex; align-items: center; gap: 10px;">
                <label style="font-weight: 600; white-space: nowrap; margin-bottom: 0;">Sampai Tanggal:</label>
                <input type="date" name="endDate" id="endDateInput" class="form-control" style="width: 160px;" value="<%= typeof endDateQuery !== 'undefined' ? endDateQuery : '' %>">
            </div>
            <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Filter</button>
            <a href="/dashboard" class="btn btn-secondary" style="text-decoration: none;"><i class="fas fa-sync"></i> Reset</a>
            
            <a href="/dashboard/export-excel?startDate=<%= typeof startDateQuery !== 'undefined' ? startDateQuery : '' %>&endDate=<%= typeof endDateQuery !== 'undefined' ? endDateQuery : '' %>" class="btn btn-secondary btn-print" style="text-decoration: none; margin-left: auto;" download>
                <i class="fas fa-file-excel"></i> Export Excel
            </a>
        </form>
    </div>

    <!-- Top Stats -->
    <div class="row mb-4">
        <div class="col-md-4 mb-4">
            <%- include('partials/stat-card', {
                title: 'PENDAPATAN (Berdasarkan Tanggal)',
                id: 'valPendapatan',
                rawValue: dashboardStats.totalPemasukanGlobal,
                formattedValue: 'Rp ' + dashboardStats.totalPemasukanGlobal.toLocaleString('id-ID'),
                iconClass: 'fas fa-wallet'
            }) %>
        </div>
        <div class="col-md-4 mb-4">
            <%- include('partials/stat-card', {
                title: 'TUNGGAKAN',
                id: 'valTopTunggakan',
                rawValue: dashboardStats.totalTunggakan,
                formattedValue: 'Rp ' + dashboardStats.totalTunggakan.toLocaleString('id-ID'),
                iconClass: 'fas fa-file-invoice-dollar',
                iconStyle: 'color: rgba(239, 68, 68, 0.1);'
            }) %>
        </div>
        <div class="col-md-4 mb-4">
            <%- include('partials/stat-card', {
                title: 'TARGET PENDAPATAN',
                id: 'valTopTarget',
                rawValue: dashboardStats.totalTargetPendapatan,
                formattedValue: 'Rp ' + dashboardStats.totalTargetPendapatan.toLocaleString('id-ID'),
                iconClass: 'fas fa-bullseye',
                iconStyle: 'color: rgba(217, 119, 6, 0.1);'
            }) %>
        </div>
    </div>

    <% 
      // Helper function to render table for any stats block
      function renderStatsTable(stats, groupId, showSantri = true) { 
    %>
        <div class="table-responsive stat-group" data-group="<%= groupId %>">
            <table class="table table-bordered table-striped" style="margin-bottom: 0; table-layout: fixed; width: 100%;">
                <tr>
                    <% if(showSantri) { %>
                        <th style="width: 22%; text-align: center;">JML SANTRI</th>
                        <th style="width: 28%; text-align: center;">TOTAL TAGIHAN</th>
                        <th colspan="2" style="width: 50%; text-align: center;">TOTAL BAYAR</th>
                    <% } else { %>
                        <th colspan="2" style="width: 50%; text-align: center;">TOTAL TAGIHAN</th>
                        <th colspan="2" style="width: 50%; text-align: center;">TOTAL BAYAR</th>
                    <% } %>
                </tr>
                <tr>
                    <% if(showSantri) { %>
                        <td class="text-center val-santri" data-original="<%= stats.jumlahSantri %>"><%= stats.jumlahSantri %></td>
                        <td class="text-center val-tagihan" data-original="<%= stats.totalTagihan %>">Rp <%= stats.totalTagihan.toLocaleString('id-ID') %></td>
                        <td class="text-center val-bayar" data-original="<%= stats.totalBayar %>">Rp <%= stats.totalBayar.toLocaleString('id-ID') %></td>
                        <td class="text-center font-weight-bold val-persen-bayar" style="color: var(--primary);"><%= stats.persenBayar %></td>
                    <% } else { %>
                        <td class="text-center val-tagihan" colspan="2" data-original="<%= stats.totalTagihan %>">Rp <%= stats.totalTagihan.toLocaleString('id-ID') %></td>
                        <td class="text-center val-bayar" data-original="<%= stats.totalBayar %>">Rp <%= stats.totalBayar.toLocaleString('id-ID') %></td>
                        <td class="text-center font-weight-bold val-persen-bayar" style="color: var(--primary);"><%= stats.persenBayar %></td>
                    <% } %>
                </tr>
                <tr>
                    <th colspan="2" style="width: 50%; text-align: center;">TUNGGAKAN</th>
                    <th colspan="2" style="width: 50%; text-align: center;">PENGELUARAN</th>
                </tr>
                <tr>
                    <td class="text-center val-tunggakan" colspan="2" data-original="<%= stats.tunggakan %>">Rp <%= stats.tunggakan.toLocaleString('id-ID') %></td>
                    <td class="text-center text-danger val-persen-tunggakan" style="display: none;"><%= stats.persenTunggakan %></td>
                    <td class="text-center val-pengeluaran" colspan="2" data-original="<%= stats.pengeluaran %>">Rp <%= stats.pengeluaran.toLocaleString('id-ID') %></td>
                </tr>
                <tr><th colspan="4" class="text-center">SALDO</th></tr>
                <tr><td colspan="4" class="text-center font-weight-bold val-saldo" data-original="<%= stats.saldo %>">Rp <%= stats.saldo.toLocaleString('id-ID') %></td></tr>
            </table>
        </div>
    <% } %>

    <!-- Main Tables -->
    <div class="row mb-4">
        <!-- Madrasah Total -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">INFORMASI KEUANGAN MADRASAH</div>
                <% renderStatsTable(dashboardStats.madrasahTotal, 'madrasah-total', true); %>
            </div>
        </div>
        <!-- Madrasah Baru -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">INFO KEUANGAN SANTRI BARU</div>
                <% renderStatsTable(dashboardStats.madrasahBaru, 'madrasah-baru', false); %>
            </div>
        </div>
        <!-- Madrasah Lama -->
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">INFO KEUANGAN DAFTAR ULANG</div>
                <% renderStatsTable(dashboardStats.madrasahLama, 'madrasah-lama', false); %>
            </div>
        </div>
    </div>

    <!-- Unit Baru Tables -->
    <div class="row mb-4">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">KEUANGAN SANTRI BARU PAUDQu</div>
                <% renderStatsTable(dashboardStats.baru.PAUDQu, 'baru-paudqu', true); %>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">KEUANGAN SANTRI BARU TPQ</div>
                <% renderStatsTable(dashboardStats.baru.TPQ, 'baru-tpq', true); %>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">KEUANGAN SANTRI BARU MDT</div>
                <% renderStatsTable(dashboardStats.baru.MDT, 'baru-mdt', true); %>
            </div>
        </div>
    </div>

    <!-- Unit Lama Tables -->
    <div class="row mb-4">
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">KEUANGAN DAFTAR ULANG PAUDQu</div>
                <% renderStatsTable(dashboardStats.lama.PAUDQu, 'lama-paudqu', true); %>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">KEUANGAN DAFTAR ULANG TPQ</div>
                <% renderStatsTable(dashboardStats.lama.TPQ, 'lama-tpq', true); %>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header">KEUANGAN DAFTAR ULANG MDT</div>
                <% renderStatsTable(dashboardStats.lama.MDT, 'lama-mdt', true); %>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <!-- Rekap Baru -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">REKAPITULASI PENDAFTAR SANTRI BARU</div>
                <div style="overflow-x: auto;" class="rekap-group">
                    <table class="table table-bordered table-striped" style="margin-bottom: 0; min-width: 500px;">
                        <tr>
                            <th>PAUDQu A</th>
                            <th>PAUDQu B</th>
                            <th>TPQ A</th>
                            <th>TPQ B</th>
                            <th>TOTAL PAUDQu</th>
                            <th>TOTAL TPQ</th>
                        </tr>
                        <tr>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapBaru['PAUDQu A'] %>"><%= dashboardStats.rekapBaru['PAUDQu A'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapBaru['PAUDQu B'] %>"><%= dashboardStats.rekapBaru['PAUDQu B'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapBaru['TPQ A'] %>"><%= dashboardStats.rekapBaru['TPQ A'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapBaru['TPQ B'] %>"><%= dashboardStats.rekapBaru['TPQ B'] %></td>
                            <td class="text-center font-weight-bold val-rekap-total-paudqu" data-original="<%= dashboardStats.rekapBaru['PAUDQu A'] + dashboardStats.rekapBaru['PAUDQu B'] %>"><%= dashboardStats.rekapBaru['PAUDQu A'] + dashboardStats.rekapBaru['PAUDQu B'] %></td>
                            <td class="text-center font-weight-bold val-rekap-total-tpq" data-original="<%= dashboardStats.rekapBaru['TPQ A'] + dashboardStats.rekapBaru['TPQ B'] + dashboardStats.rekapBaru['TPQ C'] %>"><%= dashboardStats.rekapBaru['TPQ A'] + dashboardStats.rekapBaru['TPQ B'] + dashboardStats.rekapBaru['TPQ C'] %></td>
                        </tr>
                        <tr>
                            <th>MDT 1</th>
                            <th>MDT 2</th>
                            <th>MDT 3</th>
                            <th>MDT 4</th>
                            <th>TOTAL MDT</th>
                            <th>TOTAL PENDAFTAR</th>
                        </tr>
                        <tr>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapBaru['MDT 1'] %>"><%= dashboardStats.rekapBaru['MDT 1'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapBaru['MDT 2'] %>"><%= dashboardStats.rekapBaru['MDT 2'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapBaru['MDT 3'] %>"><%= dashboardStats.rekapBaru['MDT 3'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapBaru['MDT 4'] %>"><%= dashboardStats.rekapBaru['MDT 4'] %></td>
                            <td class="text-center font-weight-bold val-rekap-total-mdt" data-original="<%= dashboardStats.rekapBaru['MDT 1'] + dashboardStats.rekapBaru['MDT 2'] + dashboardStats.rekapBaru['MDT 3'] + dashboardStats.rekapBaru['MDT 4'] %>"><%= dashboardStats.rekapBaru['MDT 1'] + dashboardStats.rekapBaru['MDT 2'] + dashboardStats.rekapBaru['MDT 3'] + dashboardStats.rekapBaru['MDT 4'] %></td>
                            <td class="text-center font-weight-bold val-rekap-total-all" style="color: var(--primary); font-size: 16px;" data-original="<%= dashboardStats.madrasahBaru.jumlahSantri %>"><%= dashboardStats.madrasahBaru.jumlahSantri %></td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- Rekap Lama -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">REKAPITULASI DAFTAR ULANG SANTRI LAMA</div>
                <div style="overflow-x: auto;" class="rekap-group">
                    <table class="table table-bordered table-striped" style="margin-bottom: 0; min-width: 500px;">
                        <tr>
                            <th>PAUDQu A</th>
                            <th>PAUDQu B</th>
                            <th>TPQ A</th>
                            <th>TPQ B</th>
                            <th>TOTAL PAUDQu</th>
                            <th>TOTAL TPQ</th>
                        </tr>
                        <tr>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapLama['PAUDQu A'] %>"><%= dashboardStats.rekapLama['PAUDQu A'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapLama['PAUDQu B'] %>"><%= dashboardStats.rekapLama['PAUDQu B'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapLama['TPQ A'] %>"><%= dashboardStats.rekapLama['TPQ A'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapLama['TPQ B'] %>"><%= dashboardStats.rekapLama['TPQ B'] %></td>
                            <td class="text-center font-weight-bold val-rekap-total-paudqu" data-original="<%= dashboardStats.rekapLama['PAUDQu A'] + dashboardStats.rekapLama['PAUDQu B'] %>"><%= dashboardStats.rekapLama['PAUDQu A'] + dashboardStats.rekapLama['PAUDQu B'] %></td>
                            <td class="text-center font-weight-bold val-rekap-total-tpq" data-original="<%= dashboardStats.rekapLama['TPQ A'] + dashboardStats.rekapLama['TPQ B'] + dashboardStats.rekapLama['TPQ C'] %>"><%= dashboardStats.rekapLama['TPQ A'] + dashboardStats.rekapLama['TPQ B'] + dashboardStats.rekapLama['TPQ C'] %></td>
                        </tr>
                        <tr>
                            <th>MDT 1</th>
                            <th>MDT 2</th>
                            <th>MDT 3</th>
                            <th>MDT 4</th>
                            <th>TOTAL MDT</th>
                            <th>TOTAL PENDAFTAR</th>
                        </tr>
                        <tr>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapLama['MDT 1'] %>"><%= dashboardStats.rekapLama['MDT 1'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapLama['MDT 2'] %>"><%= dashboardStats.rekapLama['MDT 2'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapLama['MDT 3'] %>"><%= dashboardStats.rekapLama['MDT 3'] %></td>
                            <td class="text-center val-rekap" data-original="<%= dashboardStats.rekapLama['MDT 4'] %>"><%= dashboardStats.rekapLama['MDT 4'] %></td>
                            <td class="text-center font-weight-bold val-rekap-total-mdt" data-original="<%= dashboardStats.rekapLama['MDT 1'] + dashboardStats.rekapLama['MDT 2'] + dashboardStats.rekapLama['MDT 3'] + dashboardStats.rekapLama['MDT 4'] %>"><%= dashboardStats.rekapLama['MDT 1'] + dashboardStats.rekapLama['MDT 2'] + dashboardStats.rekapLama['MDT 3'] + dashboardStats.rekapLama['MDT 4'] %></td>
                            <td class="text-center font-weight-bold val-rekap-total-all" style="color: var(--primary); font-size: 16px;" data-original="<%= dashboardStats.madrasahLama.jumlahSantri %>"><%= dashboardStats.madrasahLama.jumlahSantri %></td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Pengeluaran & Ziswaf Table -->
    <div class="row mb-4">
        <!-- Pengeluaran -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header"><i class="fas fa-hand-holding-usd mr-2"></i> INFORMASI PENGELUARAN KEUANGAN SPMB</div>
                <div class="table-responsive stat-group" data-group="pengeluaran-global">
                    <table class="table table-bordered table-striped" style="margin-bottom: 0; table-layout: fixed; width: 100%;">
                        <tr>
                            <th style="width: 17%; text-align: center; white-space: normal !important; word-wrap: break-word; font-size: 11px; padding: 10px 4px;">MADRASAH (UMUM)</th>
                            <th style="width: 17%; text-align: center; white-space: normal !important; word-wrap: break-word; font-size: 11px; padding: 10px 4px;">PAUDQu</th>
                            <th style="width: 17%; text-align: center; white-space: normal !important; word-wrap: break-word; font-size: 11px; padding: 10px 4px;">TPQ</th>
                            <th style="width: 17%; text-align: center; white-space: normal !important; word-wrap: break-word; font-size: 11px; padding: 10px 4px;">MDT</th>
                            <th style="width: 32%; text-align: center; color: var(--danger); white-space: normal !important; word-wrap: break-word; font-size: 11px; padding: 10px 4px;">TOTAL PENGELUARAN</th>
                        </tr>
                        <tr>
                            <td class="text-center val-pengeluaran-unit" id="valPengeluaranMadrasah" data-original="<%= dashboardStats.pengeluaranRekap.MADRASAH %>">Rp <%= dashboardStats.pengeluaranRekap.MADRASAH.toLocaleString('id-ID') %></td>
                            <td class="text-center val-pengeluaran-unit" id="valPengeluaranPAUDQu" data-original="<%= dashboardStats.pengeluaranRekap.PAUDQu %>">Rp <%= dashboardStats.pengeluaranRekap.PAUDQu.toLocaleString('id-ID') %></td>
                            <td class="text-center val-pengeluaran-unit" id="valPengeluaranTPQ" data-original="<%= dashboardStats.pengeluaranRekap.TPQ %>">Rp <%= dashboardStats.pengeluaranRekap.TPQ.toLocaleString('id-ID') %></td>
                            <td class="text-center val-pengeluaran-unit" id="valPengeluaranMDT" data-original="<%= dashboardStats.pengeluaranRekap.MDT %>">Rp <%= dashboardStats.pengeluaranRekap.MDT.toLocaleString('id-ID') %></td>
                            <td class="text-center font-weight-bold val-pengeluaran-total" id="valPengeluaranTotal" style="color: var(--danger); font-size: 14px;" data-original="<%= dashboardStats.pengeluaranRekap.TOTAL %>">Rp <%= dashboardStats.pengeluaranRekap.TOTAL.toLocaleString('id-ID') %></td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- Ziswaf JIC Subsidy -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header"><i class="fas fa-handshake mr-2"></i> STATUS SUBSIDI SPP BEASISWA (ZISWAF JIC)</div>
                <div class="table-responsive stat-group" data-group="ziswaf-subsidy">
                    <table class="table table-bordered table-striped" style="margin-bottom: 0; table-layout: fixed; width: 100%;">
                        <tr>
                            <th style="width: 33.33%; text-align: center; white-space: normal !important; word-wrap: break-word; font-size: 11px; padding: 10px 4px;">SANTRI BARU</th>
                            <th style="width: 33.33%; text-align: center; white-space: normal !important; word-wrap: break-word; font-size: 11px; padding: 10px 4px;">DAFTAR ULANG</th>
                            <th style="width: 33.33%; text-align: center; white-space: normal !important; word-wrap: break-word; font-size: 11px; padding: 10px 4px;">TOTAL SANTRI</th>
                        </tr>
                        <tr>
                            <td class="text-center val-ziswaf-baru" data-original="<%= dashboardStats.ziswafStats.santriBaru %>"><%= dashboardStats.ziswafStats.santriBaru %></td>
                            <td class="text-center val-ziswaf-lama" data-original="<%= dashboardStats.ziswafStats.santriLama %>"><%= dashboardStats.ziswafStats.santriLama %></td>
                            <td class="text-center font-weight-bold val-ziswaf-total-santri" data-original="<%= dashboardStats.ziswafStats.totalSantri %>"><%= dashboardStats.ziswafStats.totalSantri %></td>
                        </tr>
                        <tr>
                            <th style="width: 33.33%; text-align: center; white-space: normal !important; word-wrap: break-word; font-size: 11px; padding: 10px 4px;">TARGET DANA</th>
                            <th style="width: 33.33%; text-align: center; white-space: normal !important; word-wrap: break-word; font-size: 11px; padding: 10px 4px;">REALISASI BAYAR</th>
                            <th style="width: 33.33%; text-align: center; color: var(--danger); white-space: normal !important; word-wrap: break-word; font-size: 11px; padding: 10px 4px;">SISA TUNGGAKAN</th>
                        </tr>
                        <tr>
                            <td class="text-center val-ziswaf-target" data-original="<%= dashboardStats.ziswafStats.targetDana %>">Rp <%= dashboardStats.ziswafStats.targetDana.toLocaleString('id-ID') %></td>
                            <td class="text-center val-ziswaf-bayar" data-original="<%= dashboardStats.ziswafStats.realisasiBayar %>">Rp <%= dashboardStats.ziswafStats.realisasiBayar.toLocaleString('id-ID') %></td>
                            <td class="text-center font-weight-bold val-ziswaf-tunggakan" style="color: var(--danger);" data-original="<%= dashboardStats.ziswafStats.sisaTunggakan %>">Rp <%= dashboardStats.ziswafStats.sisaTunggakan.toLocaleString('id-ID') %></td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= Transaksi Terbaru ================= -->

    <div class="table-container mb-4">
        <div class="table-header">
            <div class="table-title"><i class="fas fa-list-ul mr-2"></i> Transaksi Terbaru</div>
        </div>
        <div style="overflow-x: auto;">
            <table id="transaksiTable" class="table">
                <thead>
                    <tr>
                        <th>Tanggal</th>
                        <th>No Transaksi</th>
                        <th>Nama Santri</th>
                        <th>Jenis</th>
                        <th>Nominal</th>
                        <th>Metode</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(data.transaksiTerbaru && data.transaksiTerbaru.length > 0) { %>
                        <% data.transaksiTerbaru.forEach(trx => { %>
                            <tr data-jenis="<%= trx.jenis %>" data-nominal="<%= trx.nominal %>" data-satuan="<%= trx.satuanPendidikan || 'MADRASAH' %>">
                                <td><%= trx.tanggal %></td>
                                <td><%= trx.noTransaksi %></td>
                                <td><%= trx.namaSantri %></td>
                                <td>
                                    <span class="badge <%= trx.jenis === 'Pemasukan' ? 'badge-success' : 'badge-danger' %>">
                                        <%= trx.jenis %>
                                    </span>
                                </td>
                                <td>Rp <%= trx.nominal.toLocaleString('id-ID') %></td>
                                <td>
                                    <span class="badge <%= trx.metodePembayaran === 'Transfer' ? 'badge-info' : 'badge-warning' %>" style="<%= trx.metodePembayaran === 'Transfer' ? 'background-color: #17a2b8; color: white;' : 'background-color: #ffc107; color: black;' %>">
                                        <%= trx.metodePembayaran || 'Cash' %>
                                    </span>
                                </td>
                                <td>
                                    <% if(trx.jenis === 'Pemasukan') { %>
                                        <a href="/kwitansi/<%= trx.id %>" class="btn btn-secondary" style="padding: 5px 10px; font-size: 12px;">Cetak</a>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" style="text-align: center;">Belum ada transaksi</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Pagination UI -->
        <%- include('partials/pagination', { 
            currentPage: currentPage, 
            totalPages: totalPages, 
            totalData: totalData, 
            baseUrl: '/dashboard', 
            queryParams: (typeof startDateQuery !== 'undefined' && startDateQuery ? '&startDate='+startDateQuery : '') + 
                         (typeof endDateQuery !== 'undefined' && endDateQuery ? '&endDate='+endDateQuery : '')
        }) %>
    </div>

</div> <!-- end content-area -->



<%- include('partials/footer') %>
<script src="/js/dashboard.js"></script>