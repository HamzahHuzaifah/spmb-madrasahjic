<% if(typeof success !=='undefined' && success) { %>
    <div id="successAlert" style="position: fixed; top: 20px; right: 20px; background-color: var(--success); color: white; padding: 15px 25px; border-radius: var(--radius-sm); box-shadow: var(--shadow-md); z-index: 1000; display: flex; align-items: center; gap: 10px;">
        <i class="fas fa-check-circle"></i> <%= success %>
    </div>
<% } %>

<% if(typeof error !=='undefined' && error) { %>
    <div id="errorAlert" style="position: fixed; top: 20px; right: 20px; background-color: var(--danger); color: white; padding: 15px 25px; border-radius: var(--radius-sm); box-shadow: var(--shadow-md); z-index: 1000; display: flex; align-items: center; gap: 10px;">
        <i class="fas fa-times-circle"></i> <%= error %>
    </div>
<% } %>
