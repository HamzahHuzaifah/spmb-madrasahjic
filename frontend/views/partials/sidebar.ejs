<div class="sidebar">
    <div class="sidebar-header">
        <div class="logo">MJIC</div>
        <h2>Keuangan Madrasah JIC</h2>
    </div>
    <div class="sidebar-menu">
        <%
          const menuSections = [
            {
              title: null,
              items: [
                { href: '/dashboard', page: 'dashboard', icon: 'fas fa-home', text: 'Dashboard' },
                { href: '/input-transaksi', page: 'input-transaksi', icon: 'fas fa-plus-circle', text: 'Input Transaksi' },
                { href: '/laporan', page: 'laporan', icon: 'fas fa-chart-bar', text: 'Laporan Utama' }
              ]
            },
            {
              title: 'Santri Baru',
              items: [
                { href: '/santri', page: 'santri', icon: 'fas fa-user-graduate', text: 'Data Santri' },
                { href: '/tagihan', page: 'tagihan', icon: 'fas fa-file-invoice-dollar', text: 'Tagihan' },
                { href: '/tunggakan', page: 'tunggakan', icon: 'fas fa-exclamation-circle', text: 'Tunggakan' }
              ]
            },
            {
              title: 'Daftar Ulang',
              items: [
                { href: '/santri-daftar-ulang', page: 'santri-daftar-ulang', icon: 'fas fa-users', text: 'Data Santri' },
                { href: '/tagihan-daftar-ulang', page: 'tagihan-daftar-ulang', icon: 'fas fa-file-invoice-dollar', text: 'Tagihan' },
                { href: '/tunggakan-daftar-ulang', page: 'tunggakan-daftar-ulang', icon: 'fas fa-exclamation-circle', text: 'Tunggakan' }
              ]
            }
          ];
        %>

        <% menuSections.forEach(section => { %>
            <% if (section.title) { %>
                <div style="padding: 15px 24px 5px; font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px;"><%= section.title %></div>
            <% } %>
            <% section.items.forEach(item => { %>
                <a href="<%= item.href %>" class="menu-item <%= (typeof activePage !== 'undefined' && activePage === item.page) ? 'active' : '' %>">
                    <i class="<%= item.icon %>"></i> <%= item.text %>
                </a>
            <% }) %>
        <% }) %>

        <!-- Tombol Logout -->
        <div style="margin-top: 30px; padding: 0 24px 24px;">
            <a href="/logout" style="display: flex; align-items: center; justify-content: center; gap: 8px; padding: 12px; background-color: rgba(239, 68, 68, 0.2); color: #fca5a5; border-radius: var(--radius-sm); text-decoration: none; font-weight: 600; transition: var(--transition);" onmouseover="this.style.backgroundColor='rgba(239, 68, 68, 0.4)'; this.style.color='white';" onmouseout="this.style.backgroundColor='rgba(239, 68, 68, 0.2)'; this.style.color='#fca5a5';">
                <i class="fas fa-sign-out-alt"></i> Logout Keluar
            </a>
        </div>
    </div>
</div>

