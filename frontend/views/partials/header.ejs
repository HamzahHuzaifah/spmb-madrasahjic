<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + ' - ' : '' %>SPMB JIC
    </title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- jQuery & Select2 -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <!-- Flatpickr (Custom Datepicker) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/id.js"></script>

    <!-- Custom CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            corePlugins: { preflight: false }
        }
    </script>
    <link rel="stylesheet" href="/css/style.css?v=2">
    
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>
    <!-- Page Loader Overlay -->
    <div id="pageLoader" class="page-loader-overlay">
        <div class="page-loader-spinner-container">
            <div class="page-loader-spinner"></div>
            <div class="page-loader-text">Memuat Halaman...</div>
        </div>
    </div>

    <div class="app-container">
        <!-- Sidebar Included from Parent -->
        <%- include('sidebar') %>

            <div class="main-content">
                <div class="topbar">
                    <div class="topbar-left">
                        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle Sidebar">
                            <i class="fas fa-bars"></i>
                        </button>
                        <div class="topbar-title">
                            <%= typeof title !=='undefined' ? title : 'Dashboard' %>
                        </div>
                    </div>
                    <div class="topbar-right">
                        <div class="user-profile" style="display: flex; align-items: center; gap: 15px;">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span class="user-name">Admin MJIC</span>
                                <div class="avatar">A</div>
                            </div>
                            <a href="/logout" class="btn btn-danger" style="padding: 6px 10px; font-size: 12px; background-color: #dc2626; color: white; border-radius: 4px; text-decoration: none; display: inline-flex; align-items: center; gap: 5px;">
                                <i class="fas fa-sign-out-alt"></i><span class="logout-text">Keluar</span>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="content-area">