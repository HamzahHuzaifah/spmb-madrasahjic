<%- include('partials/header', { title: 'Tunggakan Santri Baru', activePage: 'tunggakan' }) %>

<%- include('partials/filter-bar', {
    actionUrl: '/tunggakan',
    searchQuery: typeof searchQuery !== 'undefined' ? searchQuery : '',
    filterType: 'status',
    statusQuery: typeof statusQuery !== 'undefined' ? statusQuery : '',
    actionsHtml: `
        <a href="/tunggakan/export-excel?search=${typeof searchQuery !== 'undefined' ? searchQuery : ''}&status=${typeof statusQuery !== 'undefined' ? statusQuery : ''}" class="btn btn-secondary btn-print" style="text-decoration: none;">
            <i class="fas fa-file-excel"></i> Export Excel
        </a>
    `
}) %>

<div class="table-container">
    <div class="table-header">
        <div class="table-title">Daftar Tunggakan Pembayaran</div>
    </div>
    
    <table id="dataTable">
        <thead>
            <tr>
                <th>No</th>
                <th>Nama Lengkap</th>
                <th>Satuan Pendidikan</th>
                <th>No Telepon</th>
                <th>Total Tagihan</th>
                <th>Total Bayar</th>
                <th>Sisa Bayar</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% if(tunggakan && tunggakan.length > 0) { %>
                <% tunggakan.forEach((item, index) => { %>
                <tr>
                    <td><%= index + 1 %></td>
                    <td style="font-weight: 600;"><%= item.nama %></td>
                    <td><%= item.satuanPendidikan %></td>
                    <td><%= item.noTelepon %></td>
                    <td>Rp <%= item.totalTagihan.toLocaleString('id-ID') %></td>
                    <td>Rp <%= item.totalBayar.toLocaleString('id-ID') %></td>
                    <td style="color: var(--danger); font-weight: bold;">Rp <%= item.sisaBayar.toLocaleString('id-ID') %></td>
                    <td>
                        <span class="badge <%= item.status === 'Lunas' ? 'badge-success' : 'badge-danger' %>">
                            <%= item.status %>
                        </span>
                    </td>
                </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="8" style="text-align: center;">Tidak ada data tunggakan</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <!-- Pagination UI -->
    <%- include('partials/pagination', { 
        currentPage: currentPage, 
        totalPages: totalPages, 
        totalData: totalData, 
        baseUrl: '/tunggakan', 
        queryParams: (typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '') + 
                     (typeof statusQuery !== 'undefined' && statusQuery ? '&status='+statusQuery : '')
    }) %>
</div>



<%- include('partials/footer') %>
<script src="/js/tunggakan.js"></script>
