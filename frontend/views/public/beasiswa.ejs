<div class="form-card">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); padding-bottom: 15px; margin-bottom: 15px;">
        <h2 style="margin: 0; border: none; padding: 0; color: #d35400;">Form Pendaftaran Santri Baru (Jalur Beasiswa)</h2>
        <button type="button" class="btn btn-warning" onclick="fillTestingDataPublic('beasiswa')" style="font-size: 12px; padding: 5px 10px;">Isi Data Testing</button>
    </div>
    <p style="margin-bottom: 25px; color: var(--text-muted);">Silakan pilih jenis beasiswa dan lengkapi data diri calon
        santri beserta orang tua dengan benar.</p>

    <%- include('../partials/terms-card', { type: 'beasiswa' }) %>

    <form action="/daftar/beasiswa" method="POST">

        <!-- Pilihan Jalur Beasiswa -->
        <h3 style="margin-bottom: 15px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px;">
            Jalur Pendaftaran Beasiswa</h3>
        <div class="form-group" style="margin-bottom: 30px;">
            <div class="radio-group" style="flex-direction: column; gap: 15px;">
                <label class="radio-label">
                    <input type="radio" name="jalurBeasiswa" value="Beasiswa Dhuafa" required>
                    <div>
                        <strong>Beasiswa Dhuafa</strong>
                        <div class="form-help">Potongan biaya khusus bagi kaum dhuafa (wajib melampirkan SKTM).</div>
                    </div>
                </label>
                <label class="radio-label">
                    <input type="radio" name="jalurBeasiswa" value="Beasiswa Yatim/Piatu">
                    <div>
                        <strong>Beasiswa Yatim/Piatu</strong>
                        <div class="form-help">Potongan biaya khusus anak yatim/piatu (wajib melampirkan Surat
                            Keterangan/Akta Kematian dan SKTM).</div>
                    </div>
                </label>
                <label class="radio-label">
                    <input type="radio" name="jalurBeasiswa" value="Beasiswa Pekerja/Komunitas di JIC">
                    <div>
                        <strong>Beasiswa Pekerja/Komunitas di JIC</strong>
                        <div class="form-help">Potongan biaya khusus bagi Keluarga Pegawai/PJLP/Komunitas JIC (wajib melampirkan KTP & KK orang tua serta Kartu Pegawai/PJLP/Komunitas JIC atau surat keterangan dari kantor atau komunitas)</div>
                    </div>
                </label>
                <label class="radio-label">
                    <input type="radio" name="jalurBeasiswa" value="Beasiswa Satu Keluarga">
                    <div>
                        <strong>Beasiswa Satu Keluarga</strong>
                        <div class="form-help">Potongan biaya khusus jika mendaftarkan atau menyekolahkan 2 anak kandung
                            atau lebih dalam satu keluarga. (wajib melampirkan KTP & KK orang tua)</div>
                    </div>
                </label>
            </div>
        </div>

        <!-- Data Santri -->
        <h3 style="margin-bottom: 15px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px;">
            A. Data Calon Santri</h3>

        <div class="form-group">
            <label class="required">Tingkat Pendidikan yang Didaftar</label>
            <%- include('../partials/select-pendidikan', { 
                type: 'form_baru',
                name: 'pendidikan',
                className: 'form-input',
                required: true,
                placeholder: '-- Pilih Satuan Pendidikan --'
            }) %>
        </div>

        <%- include('../partials/form-data-santri') %>

        <h3
            style="margin-top: 35px; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid #eee; padding-bottom: 10px;">
            B. Data Orang Tua / Wali</h3>

        <%- include('../partials/form-orang-tua', { 
            layout: 'stacked',
            groupClass: 'form-group',
            showEmail: true,
            required: true
        }) %>

        <div style="margin-top: 40px;">
            <button type="submit" class="btn-submit" style="background-color: #d35400;">Kirim Pendaftaran
                Beasiswa</button>
        </div>

        <div style="text-align: center; margin-top: 20px;">
            <a href="/daftar" style="color: var(--primary); text-decoration: underline; font-size: 14px;">Ingin
                mendaftar jalur reguler? Klik di sini.</a>
        </div>
    </form>
</div>