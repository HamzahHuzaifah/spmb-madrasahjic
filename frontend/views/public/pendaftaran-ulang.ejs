<div class="form-card">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); padding-bottom: 15px; margin-bottom: 15px;">
        <h2 style="margin: 0; border: none; padding: 0;">Form Pendaftaran Ulang</h2>
        <button type="button" class="btn btn-warning" onclick="fillTestingDataPublic('daftar-ulang')" style="font-size: 12px; padding: 5px 10px;">Isi Data Testing</button>
    </div>
    <p style="margin-bottom: 25px; color: var(--text-muted);">Silakan lengkapi data diri santri yang akan mendaftar
        ulang (naik tingkat).</p>

    <%- include('../partials/terms-card', { type: 'ulang' }) %>

    <form action="/daftar-ulang" method="POST">
        <!-- Data Santri -->
        <h3 style="margin-bottom: 15px; color: var(--text-main);">A. Data Calon Santri</h3>

        <div class="form-group">
            <label class="required">Jalur Pendaftaran Daftar Ulang</label>
            <div class="radio-group" style="flex-direction: column; gap: 10px;">
                <label class="radio-label">
                    <input type="radio" name="jalurPendaftaran" value="Reguler" required> Reguler
                </label>
                <label class="radio-label">
                    <input type="radio" name="jalurPendaftaran" value="Beasiswa Dhuafa"> Beasiswa Dhuafa
                </label>
                <label class="radio-label">
                    <input type="radio" name="jalurPendaftaran" value="Beasiswa Yatim/Piatu"> Beasiswa Yatim/Piatu
                </label>
            </div>
        </div>

        <div class="form-group">
            <label class="required">Unit / Satuan Pendidikan Sebelumnya</label>
            <%- include('../partials/select-pendidikan', { 
                type: 'form_unit_sebelumnya',
                name: 'pendidikanSebelumnya',
                className: 'form-input',
                required: true,
                placeholder: '-- Pilih Tingkat Sebelumnya --'
            }) %>
        </div>

        <div class="form-group">
            <label class="required">Tujuan / Lanjut Ke Tingkat</label>
            <%- include('../partials/select-pendidikan', { 
                type: 'form_lanjut_ke',
                name: 'lanjutKe',
                className: 'form-input',
                required: true,
                placeholder: '-- Pilih Tujuan Tingkat --'
            }) %>
        </div>

        <%- include('../partials/form-data-santri') %>

        <hr style="border: 0; border-top: 1px dashed var(--border); margin: 30px 0;">

        <!-- Data Orang Tua -->
        <h3 style="margin-bottom: 15px; color: var(--text-main);">B. Data Orang Tua / Wali</h3>

        <%- include('../partials/form-orang-tua', { 
            layout: 'stacked',
            groupClass: 'form-group',
            showEmail: true,
            required: true
        }) %>

        <hr style="border: 0; border-top: 1px dashed var(--border); margin: 30px 0;">

        <div style="margin-top: 40px;">
            <button type="submit" class="btn-submit">Kirim Pendaftaran Ulang</button>
        </div>

        <div style="text-align: center; margin-top: 20px;">
            <a href="/daftar" style="color: var(--primary); text-decoration: underline; font-size: 14px;">Kembali ke
                form Pendaftaran Santri Baru</a>
        </div>
    </form>
</div>