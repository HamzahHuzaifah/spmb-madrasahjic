<div class="form-card">
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); padding-bottom: 15px; margin-bottom: 15px;">
        <h2 style="margin: 0; border: none; padding: 0;">Form Pendaftaran Santri Baru</h2>
        <button type="button" class="btn btn-warning" onclick="fillTestingDataPublic('baru')" style="font-size: 12px; padding: 5px 10px;">Isi Data Testing</button>
    </div>
    <p style="margin-bottom: 25px; color: var(--text-muted);">Silakan lengkapi data diri calon santri dan orang tua
        dengan benar.</p>

    <%- include('../partials/terms-card', { type: 'reguler' }) %>

    <form action="/daftar" method="POST">
        <!-- Data Santri -->
        <h3 style="margin-bottom: 15px; color: var(--text-main);">A. Data Calon Santri</h3>

        <div class="form-group">
            <label class="required">Tingkat Pendidikan yang Didaftar</label>
            <%- include('../partials/select-pendidikan', { 
                type: 'form_baru',
                name: 'pendidikan',
                className: 'form-input',
                required: true,
                placeholder: '-- Pilih Satuan Pendidikan --'
            }) %>
        </div>

        <%- include('../partials/form-data-santri') %>

        <hr style="border: 0; border-top: 1px dashed var(--border); margin: 30px 0;">

        <!-- Data Orang Tua -->
        <h3 style="margin-bottom: 15px; color: var(--text-main);">B. Data Orang Tua / Wali</h3>

        <%- include('../partials/form-orang-tua', { 
            layout: 'stacked',
            groupClass: 'form-group',
            showEmail: true,
            required: true
        }) %>

        <div style="margin-top: 40px;">
            <button type="submit" class="btn-submit">Kirim Pendaftaran Reguler</button>
        </div>

        <div style="text-align: center; margin-top: 20px;">
            <a href="/daftar-ulang"
                style="color: var(--primary); text-decoration: underline; font-size: 14px; font-weight: bold; margin-bottom: 15px; display: block;">Ingin
                melakukan Daftar Ulang (Naik Tingkat)? Klik di sini.</a>
            <a href="/daftar/beasiswa" style="color: var(--primary); text-decoration: underline; font-size: 14px;">Ingin
                mendaftar jalur beasiswa? Klik di sini setelah mengisi form ini.</a>
        </div>
    </form>
</div>