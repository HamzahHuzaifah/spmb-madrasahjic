<%- include('partials/header', { title: 'Tagihan Daftar Ulang', activePage: 'tagihan-daftar-ulang' }) %><link rel="stylesheet" href="/css/tagihan-daftar-ulang.css">
    <%- include('partials/filter-bar', {
        actionUrl: '/tagihan-daftar-ulang',
        searchQuery: typeof searchQuery !== 'undefined' ? searchQuery : '',
        filterType: 'pendidikan',
        pendidikanType: 'form_lanjut_ke',
        pendidikanPlaceholder: 'Semua Pendidikan',
        pendidikanQuery: typeof pendidikanQuery !== 'undefined' ? pendidikanQuery : '',
        actionsHtml: `
            <a href="/tagihan-daftar-ulang/export-excel?search=${typeof searchQuery !== 'undefined' ? searchQuery : ''}&pendidikan=${typeof pendidikanQuery !== 'undefined' ? pendidikanQuery : ''}" class="btn btn-secondary btn-print" style="text-decoration: none;">
                <i class="fas fa-file-excel"></i> Export Excel
            </a>
        `
    }) %>

<div class="table-container">
    <div class="table-header">
        <div class="table-title">Daftar Tagihan Santri Daftar Ulang</div>
    </div>
    
    <table id="dataTable">
        <thead>
            <tr>
                <th>No</th>
                <th>Nama Santri</th>
                <th>Jalur Pendaftaran</th>
                <th>Unit Sebelumnya</th>
                <th>Lanjut Ke</th>
                <th>Formulir</th>
                <th>Perlengkapan</th>
                <th>SPP (Juli)</th>
                <th>Total Tagihan</th>
                <th>Terbayar</th>
                <th>Sisa Tagihan</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            <% if(tagihan && tagihan.length > 0) { %>
                <% tagihan.forEach((item, index) => { %>
                <tr>
                    <td><%= (typeof currentPage !== 'undefined' ? (currentPage - 1) * 10 : 0) + index + 1 %></td>
                    <td style="font-weight: 600;"><%= item.nama %></td>
                    <td>
                        <span class="badge <%= item.jalur === 'Reguler' ? 'badge-info' : 'badge-warning' %>">
                            <%= item.jalur || 'Reguler' %>
                        </span>
                    </td>
                    <td><%= item.satuanPendidikanSebelumnya %></td>
                    <td><span class="badge badge-info"><%= item.satuanPendidikan %></span></td>
                    <td>Rp <%= (item.formulir || 0).toLocaleString('id-ID') %></td>
                    <td>Rp <%= item.perlengkapan.toLocaleString('id-ID') %></td>
                    <td>Rp <%= item.spp.toLocaleString('id-ID') %></td>
                    <td style="font-weight: bold; color: var(--primary);">Rp <%= item.totalTagihan.toLocaleString('id-ID') %></td>
                    <% 
                        let t = tunggakanDaftarUlang.find(x => x.nama === item.nama);
                        let totalBayar = t ? t.totalBayar : 0;
                        let sisaBayar = t ? t.sisaBayar : item.totalTagihan;
                    %>
                    <td style="font-weight: bold; color: var(--success);">Rp <%= totalBayar.toLocaleString('id-ID') %></td>
                    <td style="font-weight: bold; color: var(--danger);">Rp <%= sisaBayar.toLocaleString('id-ID') %></td>
                    <td>
                        <%- include('partials/table-actions', {
                            type: 'tagihan',
                            item: item,
                            editOnClick: 'openTagihanModal(this)'
                        }) %>
                    </td>

                </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="12" style="text-align: center;">Tidak ada data tagihan</td>
                </tr>
            <% } %>
        </tbody>
    </table>

    <!-- Pagination UI -->
    <%- include('partials/pagination', { 
        currentPage: currentPage, 
        totalPages: totalPages, 
        totalData: totalData, 
        baseUrl: '/tagihan-daftar-ulang', 
        queryParams: (typeof searchQuery !== 'undefined' && searchQuery ? '&search='+searchQuery : '') + 
                     (typeof pendidikanQuery !== 'undefined' && pendidikanQuery ? '&pendidikan='+pendidikanQuery : '')
    }) %>
</div>

<!-- Modal Edit Tagihan -->


<div id="tagihanModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
        <h2 style="color: var(--primary); margin: 0;">Edit Data Tagihan</h2>
        <span class="close-modal" onclick="closeTagihanModal()">&times;</span>
    </div>
    
    <form id="editTagihanForm" method="POST" action="" onsubmit="handleAjaxSubmitGlobal(event, this)">
        <div class="form-group-modal" style="margin-bottom: 20px;">
            <label>Nama Santri</label>
            <input type="text" id="m_nama" class="form-input" readonly>
        </div>

        <div class="modal-grid">
            <div class="form-group-modal">
                <label>Formulir (Rp)</label>
                <input type="number" name="formulir" id="m_formulir" class="form-input" required>
            </div>
            <div class="form-group-modal">
                <label>Perlengkapan (Rp)</label>
                <input type="number" name="perlengkapan" id="m_perlengkapan" class="form-input" required>
            </div>
            <div class="form-group-modal">
                <label>SPP (Juli) (Rp)</label>
                <input type="number" name="spp" id="m_spp" class="form-input" required>
            </div>
        </div>
        
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeTagihanModal()">Batal</button>
            <button type="submit" class="btn btn-primary" style="margin-left: 10px;">Simpan Perubahan</button>
        </div>
    </form>
  </div>
</div>



<%- include('partials/footer') %>
<script src="/js/tagihan-daftar-ulang.js"></script>
