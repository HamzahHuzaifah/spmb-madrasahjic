<%- include('partials/header', { title: 'Input Transaksi Keuangan' , activePage: 'input-transaksi' }) %>
<link rel="stylesheet" href="/css/input-transaksi.css?v=2">

    <div class="table-container">
        <div class="table-header">
            <div class="table-title">Form Catat Transaksi</div>
        </div>

        <form action="/input-transaksi" method="POST" id="formTransaksi" onsubmit="handleAjaxSubmitGlobal(event, this)">
            <div class="row" style="margin-bottom: 10px;">
                <div class="col-md-6 mb-3">
                    <label style="display: block; margin-bottom: 8px; font-weight: 600;">Tanggal Transaksi</label>
                    <input type="date" name="tanggal" id="tanggal" class="form-control" style="width: 100%;" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label style="display: block; margin-bottom: 8px; font-weight: 600;">Jenis Transaksi</label>
                    <select name="jenisTransaksi" id="jenisTransaksi" class="form-control" style="width: 100%;" required
                        onchange="handleJenisTransaksi()">
                        <option value="">-- Pilih Jenis Transaksi --</option>
                        <option value="Pembayaran Pendaftaran Baru">Pembayaran Pendaftaran Baru</option>
                        <option value="Pembayaran Daftar Ulang">Pembayaran Daftar Ulang</option>
                        <option value="Pemasukan">Pemasukan (Selain Biaya Santri)</option>
                        <option value="Pengeluaran">Pengeluaran</option>
                    </select>
                </div>
            </div>

            <!-- Section: Pembayaran Pendaftaran -->
            <div id="sec-pendaftaran"
                style="display: none; background-color: #f8fbf8; padding: 20px; border-radius: var(--radius-sm); margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600;">Satuan Pendidikan</label>
                <select id="satuanPendidikanBaru" name="satuanPendidikan" class="form-control" style="width: 100%; margin-bottom: 15px;">
                    <option value="">-- Pilih Satuan --</option>
                    <option value="PAUDQu">PAUDQu</option>
                    <option value="TPQ">TPQ</option>
                    <option value="MDT">MDT</option>
                </select>

                <label style="display: block; margin-bottom: 8px; font-weight: 600;">Pilih Nama Pendaftar</label>
                <select name="namaSantriBaru" id="namaPendaftar" class="form-control" style="width: 100%; margin-bottom: 15px;">
                    <option value="">-- Ketik Nama untuk Mencari --</option>
                </select>
                <small style="color: var(--text-muted);">Data nama ini otomatis diambil dari form pendaftaran reguler (publik).</small>
            </div>

            <!-- Section: Pembayaran Daftar Ulang -->
            <div id="sec-daftar-ulang"
                style="display: none; background-color: #f8fbf8; padding: 20px; border-radius: var(--radius-sm); margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600;">Satuan Pendidikan</label>
                <select name="satuanPendidikanDaftarUlang" id="satuanPendidikan" class="form-control" style="width: 100%; margin-bottom: 15px;">
                    <option value="">-- Pilih Satuan --</option>
                    <option value="PAUDQu">PAUDQu</option>
                    <option value="TPQ">TPQ</option>
                    <option value="MDT">MDT</option>
                </select>

                <label style="display: block; margin-bottom: 8px; font-weight: 600;">Nama Santri</label>
                <select name="namaSantriDaftarUlang" id="namaSantriDaftarUlang" class="form-control" style="width: 100%;">
                    <option value="">-- Ketik Nama untuk Mencari --</option>
                </select>
            </div>

            <!-- Section: Pemasukan / Pengeluaran Lain -->
            <div id="sec-lainnya"
                style="display: none; background-color: #f8fbf8; padding: 20px; border-radius: var(--radius-sm); margin-bottom: 20px;">
                <div id="wrapper-satuan-pengeluaran" style="display: none;">
                    <label id="label-satuan-pengeluaran" style="display: block; margin-bottom: 8px; font-weight: 600;">Satuan Pendidikan (Khusus Pengeluaran)</label>
                    <select name="satuanPendidikanPengeluaran" id="satuanPendidikanPengeluaran" class="form-control" style="width: 100%; margin-bottom: 15px;">
                        <option value="">-- Pilih Satuan (Opsional) --</option>
                        <option value="MADRASAH">MADRASAH (Umum)</option>
                        <option value="PAUDQu">PAUDQu</option>
                        <option value="TPQ">TPQ</option>
                        <option value="MDT">MDT</option>
                    </select>
                </div>

                <label id="label-uraian" style="display: block; margin-bottom: 8px; font-weight: 600;">Uraian Transaksi</label>
                <input type="text" name="uraianLain" class="form-control" style="width: 100%; margin-bottom: 15px;"
                    placeholder="Contoh: Beli ATK Jika Pengeluaran / Dana Ziswaf Jika Pemasukan">

                <div id="wrapper-pemasukan-detail" style="display: none;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 600;">Telah Diterima Dari</label>
                    <input type="text" name="diterimaDari" class="form-control" style="width: 100%; margin-bottom: 15px;" placeholder="Nama Instansi/Lembaga/Orang">

                    <label style="display: block; margin-bottom: 8px; font-weight: 600;">Nama Pemberi (Untuk Tanda Tangan)</label>
                    <input type="text" name="namaPemberi" class="form-control" style="width: 100%; margin-bottom: 15px;" placeholder="Nama Lengkap Pemberi Dana">
                </div>

                <div id="wrapper-pengeluaran-detail" style="display: none;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 600;">Dibayarkan Kepada</label>
                    <input type="text" name="dibayarkanKepada" class="form-control" style="width: 100%; margin-bottom: 15px;" placeholder="Nama Penerima (Misal: Pak Budi)">

                    <label style="display: block; margin-bottom: 8px; font-weight: 600;">Kategori Dana</label>
                    <select name="kategoriDana" id="kategoriDana" class="form-control" style="width: 100%; margin-bottom: 10px;" onchange="handleKategoriDana()">
                        <option value="">-- Pilih Kategori --</option>
                        <option value="Operasional">Operasional</option>
                        <option value="Honorarium">Honorarium</option>
                        <option value="Transport">Transport</option>
                        <option value="Sarpras / ATK">Sarpras / ATK</option>
                        <option value="Lainnya">Lainnya</option>
                    </select>
                    <input type="text" name="kategoriDanaLainnya" id="kategoriDanaLainnya" class="form-control" style="width: 100%; margin-bottom: 15px; display: none;" placeholder="Sebutkan kategori lainnya...">

                    <label style="display: block; margin-bottom: 8px; font-weight: 600;">Rincian Pengeluaran (Opsional)</label>
                    <div id="rincian-container"></div>
                    <button type="button" class="btn btn-secondary" onclick="addRincian()" style="margin-bottom: 15px; font-size: 12px; padding: 5px 10px; border-radius: 4px; border: 1px solid #ccc; cursor: pointer;">
                        <i class="fas fa-plus"></i> Tambah Rincian
                    </button>
                </div>
            </div>

            <!-- Nominal dan Metode (Selalu Muncul kecuali jika jenis blm dipilih) -->
            <div id="sec-nominal" style="display: none;">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label style="display: block; margin-bottom: 8px; font-weight: 600;">Jumlah Nominal (Rp)</label>
                        <input type="number" id="inputNominalTotal" name="nominal" class="form-control"
                            style="width: 100%; font-size: 18px; font-weight: bold; padding: 15px;" placeholder="0" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label style="display: block; margin-bottom: 8px; font-weight: 600;">Metode Pembayaran</label>
                        <select name="metodePembayaran" class="form-control" style="width: 100%; font-size: 16px; padding: 15px;" required>
                            <option value="Cash">Cash</option>
                            <option value="Transfer">Transfer</option>
                        </select>
                    </div>
                </div>
            </div>

            <div style="margin-top: 30px; text-align: right;">
                <button type="submit" class="btn btn-primary" style="padding: 12px 30px; font-size: 16px;">
                    <i class="fas fa-save"></i> Simpan Transaksi
                </button>
            </div>
        </form>
    </div>

    
    <div class="filter-bar" style="margin-top: 30px;">
        <form method="GET" action="/input-transaksi" class="filter-form">
            <input type="text" name="search" class="form-control filter-search" placeholder="Cari Nama Santri atau No Transaksi..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
            
            <label style="font-weight: 600;">Dari Tanggal:</label>
            <input type="date" name="startDate" class="form-control filter-date" value="<%= typeof startDateQuery !== 'undefined' ? startDateQuery : '' %>">
            
            <label style="font-weight: 600;">Sampai Tanggal:</label>
            <input type="date" name="endDate" class="form-control filter-date" value="<%= typeof endDateQuery !== 'undefined' ? endDateQuery : '' %>">

            <select name="jenisTransaksi" class="form-control filter-select">
                <option value="">Semua Jenis</option>
                <option value="Pembayaran Pendaftaran Baru" <%= typeof jenisTransaksiQuery !== 'undefined' && jenisTransaksiQuery === 'Pembayaran Pendaftaran Baru' ? 'selected' : '' %>>Pendaftaran Baru</option>
                <option value="Pembayaran Daftar Ulang" <%= typeof jenisTransaksiQuery !== 'undefined' && jenisTransaksiQuery === 'Pembayaran Daftar Ulang' ? 'selected' : '' %>>Daftar Ulang</option>
                <option value="Pemasukan" <%= typeof jenisTransaksiQuery !== 'undefined' && jenisTransaksiQuery === 'Pemasukan' ? 'selected' : '' %>>Pemasukan</option>
                <option value="Pengeluaran" <%= typeof jenisTransaksiQuery !== 'undefined' && jenisTransaksiQuery === 'Pengeluaran' ? 'selected' : '' %>>Pengeluaran</option>
            </select>
            
            <button type="submit" class="btn btn-primary btn-submit-filter">Filter</button>
            <a href="/input-transaksi" class="btn btn-secondary btn-reset-filter">Reset</a>
        </form>
    </div>


    <div class="table-container">
        <div class="table-header">
            <div class="table-title">Transaksi Terbaru</div>
        </div>
        <table id="tabelTransaksi">
            <thead>
                <tr>
                    <th>Tanggal</th>
                    <th>No Transaksi</th>
                    <th>Nama Santri</th>
                    <th>Jenis</th>
                    <th>Nominal</th>
                    <th>Metode</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% if(data && data.transaksiTerbaru && data.transaksiTerbaru.length> 0) { %>
                    <% data.transaksiTerbaru.forEach(trx=> { %>
                        <tr>
                            <td>
                                <%= trx.tanggal %>
                            </td>
                            <td>
                                <%= trx.noTransaksi %>
                            </td>
                            <td>
                                <%= trx.namaSantri %>
                            </td>
                            <td>
                                <span class="badge <%= trx.jenis === 'Pemasukan' ? 'badge-success' : 'badge-danger' %>">
                                    <%= trx.jenis %>
                                </span>
                            </td>
                            <td>Rp <%= trx.nominal.toLocaleString('id-ID') %>
                            </td>
                            <td>
                                <span class="badge <%= trx.metodePembayaran === 'Transfer' ? 'badge-info' : 'badge-warning' %>" style="<%= trx.metodePembayaran === 'Transfer' ? 'background-color: #17a2b8; color: white;' : 'background-color: #ffc107; color: black;' %>">
                                    <%= trx.metodePembayaran || 'Cash' %>
                                </span>
                            </td>
                            <td>
                                <button type="button" class="btn btn-secondary" style="padding: 5px 10px; font-size: 12px; cursor: pointer; border: none; border-radius: 4px;" onclick="openKwitansiModal(<%= trx.id %>)">Cetak</button>
                                <button type="button" class="btn btn-warning" style="padding: 5px 10px; font-size: 12px; background-color: #ffc107; color: black; border: none; border-radius: 4px; cursor: pointer; margin-left: 5px;" onclick="openEditModal(<%= trx.id %>, '<%= trx.tanggal %>', <%= trx.nominal %>, '<%= trx.metodePembayaran %>')">Edit</button>
                                <button type="button" class="btn btn-danger" style="padding: 5px 10px; font-size: 12px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; margin-left: 5px;" onclick="openDeleteModal('/input-transaksi/delete/<%= trx.id %>')">Hapus</button>
                            </td>
                        </tr>
                        <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" style="text-align: center;">Belum ada transaksi</td>
                                </tr>
                                <% } %>
            </tbody>
        </table>
        
        <!-- Pagination Controls -->
        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
            <div class="pagination" style="margin-top: 20px; display: flex; justify-content: center; gap: 5px;">
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %>&search=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&startDate=<%= typeof startDateQuery !== 'undefined' ? startDateQuery : '' %>&endDate=<%= typeof endDateQuery !== 'undefined' ? endDateQuery : '' %>&jenisTransaksi=<%= typeof jenisTransaksiQuery !== 'undefined' ? jenisTransaksiQuery : '' %>" class="btn btn-secondary" style="padding: 5px 10px;">&laquo; Prev</a>
                <% } %>
                
                <% for(let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                    <a href="?page=<%= i %>&search=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&startDate=<%= typeof startDateQuery !== 'undefined' ? startDateQuery : '' %>&endDate=<%= typeof endDateQuery !== 'undefined' ? endDateQuery : '' %>&jenisTransaksi=<%= typeof jenisTransaksiQuery !== 'undefined' ? jenisTransaksiQuery : '' %>" class="btn <%= currentPage === i ? 'btn-primary' : 'btn-secondary' %>" style="padding: 5px 10px;"><%= i %></a>
                <% } %>
                
                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %>&search=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&startDate=<%= typeof startDateQuery !== 'undefined' ? startDateQuery : '' %>&endDate=<%= typeof endDateQuery !== 'undefined' ? endDateQuery : '' %>&jenisTransaksi=<%= typeof jenisTransaksiQuery !== 'undefined' ? jenisTransaksiQuery : '' %>" class="btn btn-secondary" style="padding: 5px 10px;">Next &raquo;</a>
                <% } %>
            </div>
            <div style="text-align: center; margin-top: 10px; color: #64748b; font-size: 14px;">
                Menampilkan halaman <%= currentPage %> dari <%= totalPages %> (Total: <%= totalData %> data)
            </div>
        <% } %>
    </div>


    <!-- Edit Modal -->
    <div id="editModal" class="modal">
      <div class="modal-content">
        <h3>Edit Transaksi</h3>
        <form id="editTransaksiForm" method="POST" action="" onsubmit="handleAjaxSubmitGlobal(event, this)">
            <div style="margin-bottom: 15px;">
                <label>Tanggal Transaksi</label>
                <input type="text" name="tanggal" id="editTanggal" class="form-control" required>
                <small>Format: DD Bulan YYYY (contoh: 15 Juli 2026)</small>
            </div>
            <div style="margin-bottom: 15px;">
                <label>Nominal (Rp)</label>
                <input type="number" name="nominal" id="editNominal" class="form-control" required>
            </div>
            <div style="margin-bottom: 25px;">
                <label>Metode Pembayaran</label>
                <select name="metodePembayaran" id="editMetode" class="form-control" required>
                    <option value="Cash">Cash</option>
                    <option value="Transfer">Transfer</option>
                </select>
            </div>
            <div style="display: flex; gap: 15px; justify-content: flex-end;">
                <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Batal</button>
                <button type="submit" class="btn btn-primary">Simpan Perubahan</button>
            </div>
        </form>
      </div>
    </div>

    <!-- Modal / Pesan Sukses atau Error -->
    <%- include('partials/alert-message') %>

    <!-- Kwitansi Modal (Iframe) -->
    <div id="kwitansiModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-file-invoice-dollar"></i> Preview Kwitansi</h3>
                <button type="button" onclick="closeKwitansiModal()" class="btn btn-danger"><i class="fas fa-times"></i> Tutup</button>
            </div>
            <div class="modal-body">
                <iframe id="kwitansiIframe" src=""></iframe>
            </div>
        </div>
    </div>

    <script src="/js/input-transaksi.js?v=9"></script>
<%- include('partials/footer') %>
